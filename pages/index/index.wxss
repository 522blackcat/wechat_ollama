.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-history {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.message {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}

.user-message {
  align-items: flex-end;
}

.bot-message {
  align-items: flex-start;
}

.content {
  max-width: 70%;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-wrap: break-word;
}

.user-message .content {
  background-color: #95ec69;
  color: #000;
}

.bot-message .content {
  background-color: #fff;
  color: #000;
}

.input-area {
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #e5e5e5;
  align-items: center;
}

.input-box {
  flex: 1;
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  margin-right: 20rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 10rpx;
  text-align: center;
  padding: 0;
}

.send-btn[disabled] {
  background-color: #ccc;
}