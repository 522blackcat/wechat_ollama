<view class="container">
  <scroll-view scroll-y="true" class="chat-history" scroll-into-view="{{toView}}">
    <block wx:for="{{chatHistory}}" wx:key="index">
      <view class="message {{item.role === 'user' ? 'user-message' : 'bot-message'}}" id="msg-{{index}}">
        <view class="content">{{item.content}}</view>
      </view>
    </block>
    <view id="bottom"></view>
  </scroll-view>

  <view class="input-area">
    <input class="input-box" placeholder="输入消息..." bindinput="onInput" value="{{inputValue}}" confirm-type="send" bindconfirm="sendMessage" />
    <button class="send-btn" bindtap="sendMessage" disabled="{{isLoading}}">发送</button>
  </view>
</view>